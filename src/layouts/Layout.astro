---
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

// No need to pass props; Navbar will check Astro.locals internally
---
<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <title>Astro Auth</title>
        <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js" is:inline></script>
        <script is:inline>
          const getTheme = () => {
            const saved = localStorage.getItem('theme');
            if (saved) return saved;
            
            // If no saved preference, check system, default to dark if unsure
            return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'dark'; 
          };

          if (getTheme() === 'dark') {
            document.documentElement.classList.add('dark');
          } else {
            document.documentElement.classList.remove('dark');
          }
        </script>
    </head>
    <body class="bg-inherit text-inherit flex flex-col min-h-screen">
        <Navbar />
        <slot />
      
    <Footer />
    </body>
</html>