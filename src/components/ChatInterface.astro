<script>
  // 1. Element Selectors
  const sendBtn = document.getElementById('send-btn');
  const chatInput = document.getElementById('chat-input') as HTMLTextAreaElement;
  const responseBox = document.getElementById('response-box');
  const authModal = document.getElementById('auth-modal');

  // 2. Auto-resize Textarea as user types
  chatInput?.addEventListener('input', () => {
    chatInput.style.height = 'auto';
    chatInput.style.height = chatInput.scrollHeight + 'px';
  });

  // 3. Main Send Logic
  const handleSend = async () => {
    const prompt = chatInput.value.trim();
    if (!prompt) return;

    // Clear UI for new message
    chatInput.value = '';
    chatInput.style.height = 'auto';
    responseBox!.innerHTML = '<div class="text-blue-500 animate-pulse">Gemini is thinking...</div>';
    
    try {
      const response = await fetch('/api/chat', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ 
          prompt,
          userId: "current-session-id" // Replace with your actual session/auth ID
        })
      });

      // 4. Handle "Limit Reached" (403 Forbidden)
      if (response.status === 403) {
        responseBox!.innerHTML = '<div class="text-gray-400 italic">How can I help you today?</div>';
        authModal?.classList.remove('hidden');
        return;
      }

      if (!response.ok) throw new Error('Failed to connect to Gemini');

      // 5. Handle Real-time Streaming
      responseBox!.innerHTML = ''; // Clear "thinking" state
      const reader = response.body?.getReader();
      const decoder = new TextDecoder();

      while (true) {
        const { done, value } = await reader!.read();
        if (done) break;

        const chunk = decoder.decode(value, { stream: true });
        
        // Append text chunk and scroll to bottom
        const textNode = document.createTextNode(chunk);
        responseBox?.appendChild(textNode);
        responseBox!.scrollTop = responseBox!.scrollHeight;
      }

    } catch (err) {
      console.error(err);
      responseBox!.innerHTML = '<div class="text-red-500">Sorry, something went wrong. Please try again.</div>';
    }
  };

  // 6. Event Listeners
  sendBtn?.addEventListener('click', handleSend);

  chatInput?.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' && !e.shiftKey) {
      e.preventDefault();
      handleSend();
    }
  });
</script>