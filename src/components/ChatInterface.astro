---

<main class="flex flex-col w-full max-w-4xl mx-auto px-4 h-[calc(100vh-64px)] overflow-hidden">
    
    <div 
      id="response-box" 
      class="w-full min-h-[400px] p-6 mb-6 bg-white dark:bg-zinc-900 border-2 border-gray-100 dark:border-zinc-800 text-gray-900 dark:text-zinc-100 rounded-2xl shadow-sm overflow-y-auto transition-colors duration-300"
    >
      <div class="text-gray-400 dark:text-zinc-500 italic">How can I help you today?</div>
    </div>

    <div class="w-full relative group bg-white dark:bg-zinc-900 rounded-2xl shadow-lg border-2 border-gray-100 dark:border-zinc-800 transition-all duration-300 focus-within:border-blue-500 focus-within:ring-4 focus-within:ring-blue-100/50 dark:focus-within:ring-blue-900/30">
      <div class="flex items-center p-2">
        
<textarea 
  id="chat-input" 
  rows="1"
  placeholder="Ask Gemini..." 
  class="flex-1 px-4 py-3 bg-transparent text-gray-900 dark:text-zinc-100 placeholder:text-gray-400 dark:placeholder:text-zinc-500 focus:outline-none resize-none text-base leading-relaxed"
></textarea>

        <button 
          id="send-btn" 
          class="flex items-center justify-center p-3 bg-blue-600 text-white rounded-xl transition-all duration-200 hover:bg-blue-700 hover:scale-105 active:scale-95 disabled:opacity-50 disabled:cursor-not-allowed"
        >
          <svg id="send-icon" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" />
          </svg>
        </button>
      </div>
    </div>
  </main>

<div id="auth-modal" class="hidden fixed inset-0 z-[100] flex items-center justify-center bg-zinc-900/60 backdrop-blur-sm">
  <div class="bg-white dark:bg-zinc-950 p-8 rounded-3xl shadow-2xl max-w-sm w-[90%] text-center border border-zinc-200 dark:border-zinc-800">
    <div class="text-4xl mb-4">✨</div>
    <h3 class="text-xl font-bold text-black dark:text-white mb-2">Limit Reached</h3>
    <p class="text-zinc-500 text-sm mb-6">Sign in to unlock unlimited messages!</p>
    
    <div class="flex flex-col gap-3">
      <a href="/sign-in" class="py-4 bg-blue-600 text-white rounded-2xl font-bold hover:bg-blue-700">Sign In</a>
      <button onclick="document.getElementById('auth-modal').classList.add('hidden')" class="text-zinc-400 text-sm">Maybe later</button>
    </div>
  </div>
</div>

