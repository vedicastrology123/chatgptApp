<script>
  // This code now "lives" with the UI it controls
  const chatInput = document.getElementById('chat-input') as HTMLInputElement;
  const sendBtn = document.getElementById('send-btn');

  sendBtn?.addEventListener('click', handleSendMessage);

  async function handleSendMessage() {
    const prompt = chatInput?.value.trim();
    if (!prompt) return;

    // 1. FRESH CHECK
    const isLoggedIn = document.cookie.includes('auth_session');
    let currentCount = Number(localStorage.getItem('guest_chat_count') || '0');

    // 2. THE LOCK
    if (!isLoggedIn && currentCount >= 3) {
      document.getElementById('auth-modal')?.classList.remove('hidden');
      return; // 🛑 STOPS HERE
    }

    // 3. THE MOCK / API CALL
    console.log("Success! Count is currently:", currentCount);
    
    // Increment ONLY for guests
    if (!isLoggedIn) {
      currentCount++;
      localStorage.setItem('guest_chat_count', currentCount.toString());
    }

    chatInput.value = "";
  }
</script>