<script>
// 1. Initialize DOM Elements
const responseBox = document.getElementById('response-box');
const chatInput = document.getElementById('chat-input') as HTMLTextAreaElement;
const sendBtn = document.getElementById('send-btn');
const authModal = document.getElementById('auth-modal');

// Add this at the very top of your script tag
if (import.meta.env.DEV) {
  // Check if we already reset during this browser session
  if (!sessionStorage.getItem('dev_reset_performed')) {
    localStorage.removeItem('guest_chat_count');
    sessionStorage.setItem('dev_reset_performed', 'true');
    console.log("🛠️ Dev Mode: Guest chat count reset to 0 for this session.");
  }
}

// --- TEMPORARY TESTING RESET ---
// if (import.meta.env.DEV) {
//     // This will force the count to 0 EVERY time you refresh the page 
//     // while you are working on the UI.
//     localStorage.setItem('guest_chat_count', '0');
//     console.log("🛠️ Dev Mode: Count FORCED to 0 for testing.");
// }

const handleSend = async () => {
  if (!chatInput || !responseBox) return;

  const prompt = chatInput.value.trim();
  if (!prompt) return;

  // --- STAGE 1: GUEST LIMIT CHECK ---

  const currentCount = parseInt(localStorage.getItem('guest_chat_count') || '0', 10);

  // 1. Pre-check: Is the user ALREADY at the limit?
  if (currentCount >= 3) {
    authModal?.classList.remove('hidden');
    return;
  }


  // --- STAGE 2: UI PREPARATION ---
  // Clear the "you today?" text if it's the first message
if (responseBox.innerHTML.includes("How can I help you today?") || responseBox.children.length === 0) {
  responseBox.innerHTML = ''; 
}

  // Clear input field
  chatInput.value = '';
  chatInput.style.height = 'auto';

  // Add the Tailwind 4 Typing Indicator
  const typingId = 'typing-' + Date.now();
  const typingHTML = `
    <div id="${typingId}" class="flex items-center gap-1.5 p-4 bg-zinc-100 dark:bg-zinc-800/50 rounded-2xl w-fit mb-4 animate-in fade-in duration-300">
      <span class="w-1.5 h-1.5 bg-blue-600 rounded-full animate-bounce [animation-delay:-0.3s]"></span>
      <span class="w-1.5 h-1.5 bg-blue-600 rounded-full animate-bounce [animation-delay:-0.15s]"></span>
      <span class="w-1.5 h-1.5 bg-blue-600 rounded-full animate-bounce"></span>
    </div>
  `;
  responseBox.insertAdjacentHTML('beforeend', typingHTML);
  responseBox.scrollTop = responseBox.scrollHeight;

  try {
    // --- STAGE 3: API CALL ---

// --- STAGE 3: API CALL ---
const response = await fetch('/api/chat', {
  method: 'POST',
  headers: { 'Content-Type': 'application/json' },
  body: JSON.stringify({ prompt })
});

// 1. Handle Google Gemini Quota (429) - Reset at 12:30 PM
if (response.status === 429) {
  document.getElementById(typingId)?.remove();
  
  // Cleanly wipe the response box if the welcome message is still there 
  if (responseBox.innerText.includes("How can I help")) {
    responseBox.innerHTML = '';
  }

  const quotaHTML = `
    <div class="flex flex-col items-center p-6 bg-amber-50 dark:bg-amber-900/20 border border-amber-200 dark:border-amber-800/50 rounded-2xl mb-4 text-center mx-4 shadow-sm animate-in fade-in zoom-in duration-300">
      <div class="text-amber-500 mb-2">⏳</div>
      <span class="text-amber-600 dark:text-amber-400 font-bold text-sm mb-1">Google Quota Limit Reached</span>
      <p class="text-amber-700 dark:text-amber-300 text-[11px] leading-relaxed max-w-[200px]">
        The free Gemini API resets daily. <br/> 
        Service resumes at <span class="font-bold underline text-amber-600">12:30 PM IST</span>. [cite: 26]
      </p>
    </div>
  `;
  
  responseBox.insertAdjacentHTML('beforeend', quotaHTML); // [cite: 27]
  responseBox.scrollTo({ top: responseBox.scrollHeight, behavior: 'smooth' }); // [cite: 27]
  return; 
}

// 2. Handle Forbidden (403) or other auth issues
if (response.status === 403) {
  document.getElementById(typingId)?.remove();
  authModal?.classList.remove('hidden');
  return;
}

if (!response.ok) throw new Error('Failed to connect');



    // --- STAGE 4: SUCCESS & STREAMING ---
    // Increment the count now that we know the request worked
    localStorage.setItem('guest_chat_count', (currentCount + 1).toString());

    // Remove typing indicator and prepare text container
    document.getElementById(typingId)?.remove();
    const messageDiv = document.createElement('div');
    messageDiv.className = "mb-6 text-zinc-800 dark:text-zinc-200 leading-relaxed text-sm antialiased border-l-2 border-blue-500 pl-4";
    responseBox.appendChild(messageDiv);

    const reader = response.body?.getReader();
    const decoder = new TextDecoder();

    while (true) {
      const { done, value } = await reader!.read();
      if (done) break;

      const chunk = decoder.decode(value, { stream: true });
      messageDiv.append(chunk);
      responseBox.scrollTop = responseBox.scrollHeight;
    }

  } catch (err) {
    console.error(err);
    document.getElementById(typingId)?.remove();
    responseBox.insertAdjacentHTML('beforeend', 
      '<div class="text-red-500 text-xs mb-4">Something went wrong. Please try again.</div>'
    );
  }
};

// --- STAGE 5: EVENT LISTENERS ---
sendBtn?.addEventListener('click', handleSend);

chatInput?.addEventListener('keydown', (e) => {
  if (e.key === 'Enter' && !e.shiftKey) {
    e.preventDefault();
    handleSend();
  }
});
</script>

