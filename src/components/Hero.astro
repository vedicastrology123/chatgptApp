---
const { user } = Astro.props;
---

<main class="relative z-10 flex h-fit w-full flex-col items-center justify-start pt-16 px-4">
  <section class="flex flex-col items-center text-center max-w-2xl">
    <h1 class="text-gradient-clip font-bold text-[24px] md:text-[40px] tracking-tight mb-4 py-1">
      Better Auth + Astro + Prismasas
    </h1>

    {user && (
      <div class="animate-in fade-in slide-in-from-bottom-2 duration-500">
        <p class="text-lg text-gray-600">
          Welcome back, <span class="font-semibold text-gray-900">{user.name}</span>
        </p>
      </div>
    )}
  </section>
</main>