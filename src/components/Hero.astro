---
const { user } = Astro.props;
---

<main class="relative z-10 flex h-fit w-full flex-col items-center justify-start pt-3 px-4">
  <section class="flex flex-col items-center text-center max-w-2xl">
    <h1 class="text-gradient-clip font-bold text-[16px] md:text-[24px] tracking-tight mb-1 py-1">
      Professional Astrology Consultation and AI Insights.
    </h1>
    <p class="text-gradient-clip font-normal text-[16px] md:text-[24px] tracking-tight mb-1 pt-1 py-1">
      by Steve Hora, Vedic Astrologer.
    </p>
    {user ? (
      <div class="animate-in fade-in slide-in-from-bottom-2 duration-500">
        {/* <p class="text-lg text-gray-600">
          Welcome back, <span class="font-semibold text-gray-900">{user.name}</span>
        </p> */}
      </div>
    ) : (
      <div class="animate-in fade-in slide-in-from-bottom-2 duration-500 mb-2">
        <p class="text-lg text-gray-600">
          Welcome Guest, Please sign up, or sign in if already an user. <span class="font-semibold text-gray-900"></span>
        </p>
      </div>
    )}
  </section>
</main>